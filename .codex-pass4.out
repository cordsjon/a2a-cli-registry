   425	
   426	async def _mcp_call(tool_name: str, arguments: dict) -> str:
   427	    """Dispatch one tool call to the cli-registry MCP and return its text payload.
   428	
   429	    Uses the MCP streamable-HTTP protocol (initialize -> tools/call) via the
   430	    official SDK, so the stateful session/SSE handshake (F7) is handled for us.
   431	    Bearer + URL come from config (resolve_cli_registry_token / cli_registry_url).
   432	    Isolated as a module-level seam so handlers are testable without a live MCP.
   433	    """
   434	    from mcp import ClientSession
   435	    from mcp.client.streamable_http import streamablehttp_client
   436	
   437	    from hermes_adapter.config import hermes_cfg, resolve_cli_registry_token
   438	
   439	    url = hermes_cfg.cli_registry_url
   440	    token = resolve_cli_registry_token(hermes_cfg)
   441	    headers = {"Authorization": f"Bearer {token}"} if token else {}
   442	
   443	    async with streamablehttp_client(url, headers=headers) as (read, write, _):
   444	        async with ClientSession(read, write) as session:
   445	            await session.initialize()
   446	            result = await session.call_tool(tool_name, arguments)
   447	    if getattr(result, "isError", False):
   448	        raise RuntimeError(f"cli-registry MCP {tool_name} returned an error result")
   449	    parts = []
   450	    for block in getattr(result, "content", []) or []:
   451	        text = getattr(block, "text", None)
   452	        if text:
   453	            parts.append(text)
   454	    return "\n".join(parts)
   455	
