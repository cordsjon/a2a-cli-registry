   581	    Anything else (parse error, unexpected shape) yields []."""
   582	    try:
   583	        data = json.loads(raw)
   584	    except (ValueError, TypeError):
   585	        return []
   586	    if isinstance(data, dict):
   587	        content = data.get("content")
   588	        if isinstance(content, list) and content:
   589	            inner = content[0].get("json") if isinstance(content[0], dict) else None
   590	            if isinstance(inner, list):
