   848	            se_all, se_healthy = _candidate_slugs(se_catalog)
   849	        except Exception:  # noqa: BLE001 — fall through to the output-term search
   850	            se_all, se_healthy = set(), set()
   851	        if se_all:
   852	            all_slugs, healthy, query_term = se_all, se_healthy, side_effect_term
   853	    if not all_slugs:
