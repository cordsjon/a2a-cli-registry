   501	async def _infer_capability_tags(goal: str, vocab: set[str] | None = None) -> dict:
   502	    """Goal -> {goal_inputs, goal_outputs, side_effects}. Raises ValueError if the
   503	    model output is unparseable or names no output capability (never fabricates).
   504	
   505	    If `vocab` is supplied (the registry's real <category>:<subtype> tags), any
   506	    inferred tag outside it triggers one retry that tells the model exactly which
   507	    tags were rejected; still out-of-vocab after the retry raises ValueError.
   508	    `vocab=None` skips the check (e.g. registry vocab fetch failed upstream) —
   509	    the caller degrades to the pre-fix unconstrained behavior rather than
   510	    hard-failing on an unrelated outage."""
   511	    from hermes_adapter.config import hermes_cfg
   512	    from hermes_adapter.loop import _API_ROUTER_URL, _call_gateway as _fn
   513	
   514	    headers = {"Content-Type": "application/json"}
   515	
   516	    async def _call(user_msg: str) -> dict:
   517	        async with httpx.AsyncClient(timeout=_HTTP_TIMEOUT_S) as client:
   518	            content, _usage = await _fn(
   519	                client, _API_ROUTER_URL, headers,
   520	                _TAG_INFER_SYSTEM, user_msg, hermes_cfg.model, _TAG_INFER_MAX_TOKENS, 1.0,
   521	            )
   522	        try:
   523	            data = json.loads(content.strip())
   524	        except (json.JSONDecodeError, AttributeError) as e:
   525	            raise ValueError(f"tag inference returned non-JSON: {e}") from e
   526	        gi = data.get("goal_inputs") or []
   527	        go = data.get("goal_outputs") or []
   528	        se = data.get("side_effects") or []
   529	        if not isinstance(go, list) or not go:
   530	            raise ValueError("tag inference produced no goal_outputs")
   531	        # The model is instructed to return tag strings, but nothing enforces that
   532	        # shape — coerce here so every downstream consumer (set(), sorted()) can
   533	        # trust a flat list of strings instead of raising on stray dict/list tags.
   534	        gi = [t for t in gi if isinstance(t, str)]
   535	        go = [t for t in go if isinstance(t, str)]
   536	        se = [t for t in se if isinstance(t, str)]
   537	        if not go:
   538	            raise ValueError("tag inference produced no valid string goal_outputs")
   539	        return {"goal_inputs": gi, "goal_outputs": go, "side_effects": se}
