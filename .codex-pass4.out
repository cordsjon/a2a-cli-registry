     3	from dataclasses import dataclass, field
     4	from sqlmodel import select
     5	from core.models import Capability, CliEdge
     6	
     7	# excluded-by-default side-effect classes (fail-UNSAFE): destructive + unknown
     8	_UNSAFE_DEFAULT = {"destructive", "unknown"}
     9	_CONFIDENCE_RANK = {"declared": 0, "inferred": 1}   # lower rank = higher confidence
    10	
    11	
    12	@dataclass(order=False)
    13	class Chain:
    14	    slugs: list[str]
    15	    length: int
    16	    side_effect_count: int
    17	    min_confidence_rank: int       # max over hops of _CONFIDENCE_RANK (worst hop)
    18	    hops: list[dict] = field(default_factory=list)
    19	
    20	    def sort_key(self):
    21	        # length asc, side-effect count asc, min-confidence DESC (rank asc since
    22	        # lower rank = higher confidence), slug-sequence asc (final tiebreak)
    23	        return (self.length, self.side_effect_count, self.min_confidence_rank, tuple(self.slugs))
    24	
    25	
    26	def _cap_index(session):
    27	    idx = {}
    28	    for c in session.exec(select(Capability)).all():
    29	        idx.setdefault(c.cli_slug, []).append(c)
    30	    return idx
    31	
    32	
    33	def _slug_side_effect(caps_for_slug) -> str:
    34	    order = ["destructive", "unknown", "network", "external", "writes-fs", "none"]
    35	    present = {c.side_effect for c in caps_for_slug}
    36	    for level in order:
    37	        if level in present:
    38	            return level
    39	    return "unknown"
    40	
    41	
    42	def _slug_confidence_rank(caps_for_slug) -> int:
    43	    return max(_CONFIDENCE_RANK.get(c.confidence, 1) for c in caps_for_slug)
    44	
    45	
    46	def _hop_excluded(caps_for_slug, allow_side_effects) -> bool:
    47	    """Fail-UNSAFE prune decision for a single hop (slug). A hop is excluded if:
    48	      - its worst side_effect is in {destructive, unknown} and that class is NOT
    49	        allowed, OR
    50	      - it carries an INFERRED side_effect with real blast radius (non-"none")
    51	        that is NOT in allow_side_effects. An inferred side_effect is unverified,
    52	        so it must fail UNSAFE (spec §8, lines 34/228). An inferred "none" hop
    53	        has no blast radius and is always allowed (confidence alone never excludes).
    54	    The operator override is unified on allow_side_effects: opting into a
    55	    side-effect CLASS accepts that blast radius whether declared or inferred.
    56	    """
    57	    se = _slug_side_effect(caps_for_slug)
    58	    if se == "none":
    59	        return False
    60	    excluded = _UNSAFE_DEFAULT - allow_side_effects
    61	    if se in excluded:
    62	        return True
    63	    # writes-fs / network: excluded by default only when INFERRED and not allowed.
    64	    if se in allow_side_effects:
    65	        return False
    66	    # is the (non-none, non-unsafe-default) side_effect carried by an inferred cap?
    67	    for c in caps_for_slug:
    68	        if c.side_effect == se and _CONFIDENCE_RANK.get(c.confidence, 1) >= 1:
    69	            return True
    70	    return False
    71	
    72	
    73	def _slug_produces(caps_for_slug) -> set[str]:
    74	    return {p for c in caps_for_slug for p in c.output_types.split(",") if p}
    75	
    76	
    77	def _slug_consumes(caps_for_slug) -> set[str]:
    78	    return {p for c in caps_for_slug for p in c.input_types.split(",") if p}
    79	
    80	
    81	def plan_chain(session, goal_inputs, goal_outputs, allow_side_effects=None,
    82	               max_chain_depth=4, max_candidate_chains=100):
    83	    allow_side_effects = set(allow_side_effects or [])
    84	    caps = _cap_index(session)
    85	    adjacency = {}
    86	    for e in session.exec(select(CliEdge)).all():
    87	        adjacency.setdefault(e.from_slug, []).append((e.to_slug, e.via_type))
    88	
    89	    goal_in, goal_out = set(goal_inputs), set(goal_outputs)
    90	    # An empty goal_in means "no input constraint" (a query-only goal like
    91	    # "list files" or "check status"). `_slug_consumes(c) & goal_in` is always
    92	    # empty/falsy when goal_in is empty, which used to make EVERY CLI —
    93	    # including the ones with input_types="" that exist specifically for this
    94	    # case — permanently unreachable. Only match no-declared-input CLIs when
    95	    # goal_in is empty; a CLI with a real declared input type still requires
    96	    # the caller to name it (goal_in non-empty and intersecting).
    97	    if goal_in:
    98	        starts = [s for s, c in caps.items() if _slug_consumes(c) & goal_in]
    99	    else:
   100	        starts = [s for s, c in caps.items() if not _slug_consumes(c)]
   101	    candidates = []
   102	
   103	    for start in starts:
   104	        # BFS state: (path, visited, hops). Cycle guard via visited set.
   105	        q = deque([([start], {start}, [])])
   106	        while q:
   107	            path, visited, hops = q.popleft()
   108	            tail = path[-1]
   109	            # fail-UNSAFE prune: destructive/unknown OR inferred-side-effect
   110	            if _hop_excluded(caps[tail], allow_side_effects):
   111	                continue
   112	            if _slug_produces(caps[tail]) & goal_out:
   113	                candidates.append(_finalize(path, caps, hops))
   114	                continue
   115	            if len(path) >= max_chain_depth:
   116	                continue
   117	            for (nxt, via) in adjacency.get(tail, []):
   118	                if nxt in visited:
   119	                    continue                       # cycle guard
   120	                q.append((path + [nxt], visited | {nxt},
   121	                          hops + [{"from": tail, "to": nxt, "via_type": via}]))
   122	
   123	    candidates.sort(key=lambda c: c.sort_key())
   124	    return candidates[:max_candidate_chains]
   125	
   126	
   127	def _finalize(path, caps, hop_trace) -> Chain:
   128	    se_count = sum(1 for s in path if _slug_side_effect(caps[s]) != "none")
   129	    min_conf = max(_slug_confidence_rank(caps[s]) for s in path)
   130	    hops = []
   131	    for i, s in enumerate(path):
   132	        se = _slug_side_effect(caps[s])
   133	        conf = "inferred" if _slug_confidence_rank(caps[s]) else "declared"
   134	        prov = f"{se} ({conf}{', unverified' if conf == 'inferred' else ''})"
   135	        hop = {"slug": s, "side_effect": se, "provenance": prov}
   136	        if i > 0:
   137	            edge = hop_trace[i - 1]
   138	            hop["from"] = edge["from"]
   139	            hop["to"] = edge["to"]
   140	            hop["via_type"] = edge["via_type"]
   141	        hops.append(hop)
   142	    return Chain(slugs=path, length=len(path), side_effect_count=se_count,
   143	                 min_confidence_rank=min_conf, hops=hops)
