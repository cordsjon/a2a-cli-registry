    36	    try:
    37	        payload = op.handler(session, **arguments)
    38	    except (TypeError, ValueError) as exc:
    39	        return _error_block(f"invalid input: {exc}")
    40	    # structured JSON content block — capability model appears INSIDE as data
    41	    return {"content": [{"type": "json", "json": payload}]}
    70	
    71	def mcp_tool_names() -> list[str]:
    72	    """The MCP tool names this HTTP surface serves — straight from the registry."""
    73	    return [op.mcp_tool for op in OPS]
    74	
    75	
    76	def _make_handler(session, op):
    77	    """Return an MCP tool handler bound to *op* and *session*.
    78	
    79	    The handler advertises the op's REAL top-level parameters (derived from
    80	    op.input_schema) so a normal MCP client can call e.g.
    81	    `search_cli_catalog {"query":"x"}` with TOP-LEVEL keys — matching the
    82	    in-process call_mcp_tool surface (core/mcp/server.py).
    83	
    84	    Why not `def handler(arguments: dict)` or `def handler(**arguments)`:
    85	    mcp 1.28.0's func_metadata introspects the signature. A single
    86	    `arguments: dict` param makes FastMCP advertise
    87	    {"required":["arguments"],...} — forcing clients to NEST under
    88	    {"arguments":{...}}. `**arguments` is advertised by func_metadata as a
    89	    single required STRING param named 'arguments' — also uncallable with
    90	    top-level keys. So we build an explicit signature from input_schema.
    91	
    92	    Optional params get the _MISSING sentinel as default; omitted ones are
    93	    stripped before forwarding, so call_mcp_tool receives ONLY the keys the
    94	    client actually sent — identical to the prior pass-through behavior.
    95	    NB: mcp 1.28.0 func_metadata rejects param names starting with '_', so the
    96	    parameters are the op's real schema keys (none start with '_').
    97	    """
    98	    op_name = op.mcp_tool
    99	    schema = op.input_schema
   100	    props = schema.get("properties", {})
   101	    required = set(schema.get("required", []))
   102	
   103	    def handler(**arguments):
   104	        clean = {k: v for k, v in arguments.items() if v is not _MISSING}
   105	        # call_mcp_tool re-validates clean against the op's real input_schema.
   106	        return call_mcp_tool(session, op_name, clean)
   107	
   108	    # Name the handler after the op so FastMCP's func_metadata titles the
   109	    # advertised inputSchema "<op_name>Arguments" instead of the generic
   110	    # "handlerArguments", and so each registered handler has a distinct
   111	    # __name__ (no cross-op collision in logging/introspection).
   112	    handler.__name__ = op_name
   113	    handler.__qualname__ = op_name
   114	
   115	    params = []
   116	    for pname, pschema in props.items():
   117	        annotation = _TYPE_MAP.get(pschema.get("type"), Any)
   118	        if pname in required:
   119	            params.append(inspect.Parameter(
   120	                pname, inspect.Parameter.KEYWORD_ONLY, annotation=annotation))
   121	        else:
   122	            params.append(inspect.Parameter(
   123	                pname, inspect.Parameter.KEYWORD_ONLY,
   124	                annotation=annotation, default=_MISSING))
   125	    handler.__signature__ = inspect.Signature(params)
     1	from core.ops_registry import OPS, validate_input as _validate_input_shared
     2	
     3	_BY_SKILL = {o.a2a_skill: o for o in OPS}
     4	
     5	
     6	def _validate_input(op, input_dict: dict):
     7	    """Validate input keys and types against op.input_schema. Returns error string or None."""
     8	    return _validate_input_shared(op, input_dict)
     9	
    10	
    11	def handle_a2a(session, method: str, params: dict):
    12	    if method == "SendMessage":
    13	        op = _BY_SKILL.get(params.get("skill"))
    14	        if op is None:
    15	            return {"error": "unknown skill"}
    16	        input_dict = params.get("input", {})
    17	        err = _validate_input(op, input_dict)
    18	        if err:
    19	            return {"error": err}
    20	        try:
    21	            result = op.handler(session, **input_dict)
    22	        except (TypeError, ValueError) as exc:
    23	            return {"error": f"invalid input: {exc}"}
    24	        return {"result": result}            # data only; never executes a CLI
    25	    if method == "GetTask":
    26	        return {"status": "completed"}
    27	    return {"error": "unknown method"}
