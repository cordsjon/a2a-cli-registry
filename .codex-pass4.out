     3	from core.models import Capability, CliEdge
     4	
     5	_HUB_TYPES = {"text", "json"}   # bare hubs need a shared intent_tag to form an edge
     6	
     7	
     8	def _caps(session):
     9	    rows = session.exec(select(Capability)).all()
    10	    out = {}
    11	    for c in rows:
    12	        out.setdefault(c.cli_slug, []).append(c)
    13	    return out
    14	
    15	
    16	def _desired_edges(session, vocab) -> set[tuple[str, str, str]]:
    17	    caps = _caps(session)
    18	    edges = set()
    19	    for from_slug, from_caps in caps.items():
    20	        out_ports = {p.strip() for c in from_caps for p in c.output_types.split(",") if p.strip()}
    21	        from_tags = {t.strip() for c in from_caps for t in c.intent_tags.split(",") if t.strip()}
    22	        for to_slug, to_caps in caps.items():
    23	            if to_slug == from_slug:
    24	                continue
    25	            in_ports = {p.strip() for c in to_caps for p in c.input_types.split(",") if p.strip()}
    26	            to_tags = {t.strip() for c in to_caps for t in c.intent_tags.split(",") if t.strip()}
    27	            for via in out_ports & in_ports:
    28	                if not vocab.is_edge_eligible(via):
    29	                    continue                      # unregistered/unverified excluded
    30	                if via in _HUB_TYPES and not (from_tags & to_tags):
    31	                    continue                      # hub-type down-weight
    32	                edges.add((from_slug, to_slug, via))
    33	    return edges
    34	
    35	
    36	def current_edges(session) -> set[tuple[str, str, str]]:
    37	    return {(e.from_slug, e.to_slug, e.via_type) for e in session.exec(select(CliEdge)).all()}
    38	
    39	
    40	def compute_edges(session, vocab, clock, changed_slugs=None) -> list:
    41	    """Recompute edges. Atomic shadow-swap within one transaction; returns the
    42	    delta of (from,to,via_type) tuples (added union removed). Empty list = no-op."""
    43	    desired = _desired_edges(session, vocab)
    44	    existing = current_edges(session)
    45	    if changed_slugs is not None:
    46	        # incremental: only consider edges where a changed slug is an endpoint
    47	        desired = (
    48	            {e for e in desired if e[0] in changed_slugs or e[1] in changed_slugs}
    49	            | {e for e in existing if e[0] not in changed_slugs and e[1] not in changed_slugs}
    50	        )
    51	    if desired == existing:
    52	        return []                                  # no-op emits nothing
    53	    # shadow-swap: delete all, insert desired, single transaction
    54	    for e in session.exec(select(CliEdge)).all():
    55	        session.delete(e)
    56	    for (f, t, v) in desired:
    57	        session.add(CliEdge(from_slug=f, to_slug=t, via_type=v, recomputed_at=clock.now()))
    58	    session.commit()
    59	    delta = (desired - existing) | (existing - desired)
    60	    return sorted(delta)
