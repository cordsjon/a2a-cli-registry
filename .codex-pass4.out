   558	        # not an action vocabulary — so action/terminal goals ("send mail", "post
   559	        # webhook") legitimately infer domain tags with no port equivalent. After
   560	        # one corrective retry, QUARANTINE the still-rejected tags (drop them)
   561	        # rather than hard-failing the hop, mirroring admit_ports' populate-time
   562	        # behavior. Only fail if quarantine leaves no valid goal_outputs at all —
   563	        # that means the inference was genuinely unusable, not just port-less.
   564	        tags["goal_inputs"] = [t for t in tags["goal_inputs"] if t in vocab]
   565	        tags["goal_outputs"] = [t for t in tags["goal_outputs"] if t in vocab]
   566	        if not tags["goal_outputs"]:
   567	            raise ValueError(
   568	                f"tag inference produced only out-of-vocab tags after retry: {sorted(rejected)}"
   569	            )
   570	    return tags
