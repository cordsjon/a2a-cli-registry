   541	    tags = await _call(goal)
   542	    if vocab is None:
   543	        return tags
   544	
   545	    rejected = (set(tags["goal_inputs"]) | set(tags["goal_outputs"])) - vocab
   546	    if not rejected:
   547	        return tags
   548	
   549	    retry_msg = (
   550	        f"{goal}\n\nYour previous answer used these tags, which do not exist in "
   551	        f"the registry: {sorted(rejected)}. Choose ONLY from this exact vocabulary: "
   552	        f"{sorted(vocab)}."
   553	    )
   554	    tags = await _call(retry_msg)
   555	    rejected = (set(tags["goal_inputs"]) | set(tags["goal_outputs"])) - vocab
   556	    if rejected:
