    92	def validate_input(op: "Op", arguments: dict) -> "str | None":
    93	    """Validate *arguments* against op.input_schema: unknown keys, missing
    94	    required keys, AND basic JSON-Schema type checks. Returns an error string
    95	    or None if valid."""
    96	    properties = op.input_schema.get("properties", {})
    97	    allowed = set(properties.keys())
    98	    required = set(op.input_schema.get("required", []))
    99	    given = set(arguments.keys())
   100	
   101	    unknown = given - allowed
   102	    if unknown:
   103	        return f"unknown input keys: {sorted(unknown)}"
   104	
   105	    missing = required - given
   106	    if missing:
   107	        return f"missing required input keys: {sorted(missing)}"
   108	
   109	    for key, value in arguments.items():
   110	        prop_schema = properties.get(key, {})
   111	        expected_type_name = prop_schema.get("type")
   112	        if expected_type_name is None:
   113	            continue  # no type constraint declared — skip
   114	        python_type = _JSON_SCHEMA_TYPE_MAP.get(expected_type_name)
   115	        if python_type is None:
   116	            continue  # unknown JSON-schema type — skip
   117	        # bool is a subclass of int in Python; reject it for "integer" and "number"
   118	        if expected_type_name in ("integer", "number") and isinstance(value, bool):
   119	            return (
   120	                f"input '{key}' must be {expected_type_name}"
   121	                f" (got {type(value).__name__})"
   122	            )
   123	        if not isinstance(value, python_type):
   124	            return (
   125	                f"input '{key}' must be {expected_type_name}"
   126	                f" (got {type(value).__name__})"
   127	            )
   128	
   129	    return None
     1	# core/catalog/queries.py
     2	from sqlmodel import select, text
     3	from core.models import Cli, Capability, CliEdge
     4	from core.health import norm_health as _norm_health  # shared vocabulary (single source of truth)
     5	from core.planner.search import plan_chain as _plan
     6	
     7	
     8	def _sanity_columns_present(session) -> bool:
     9	    """sanity_ok/sanity_reason/sanity_checked_at are drift-only columns (same
    10	    pattern as provenance/description_provenance) added by
    11	    tools.backfill_capabilities.ensure_provenance_columns via guarded ALTER,
    12	    NOT declared on core.models.Capability. A DB that hasn't run the backfill
    13	    yet (or the in-memory test schema) won't have them -- guard the raw-SQL
    14	    read so callers still get a clean "never checked" (None) result."""
    15	    rows = session.exec(text("PRAGMA table_info(capability)")).all()
    16	    cols = {r[1] for r in rows}
    17	    return {"sanity_ok", "sanity_reason", "sanity_checked_at"} <= cols
    18	
    19	
    20	def _sanity_by_slug(session) -> dict:
    21	    if not _sanity_columns_present(session):
    22	        return {}
    23	    rows = session.exec(
    24	        text("SELECT cli_slug, sanity_ok, sanity_reason, sanity_checked_at FROM capability")
    25	    ).all()
    26	    return {r[0]: (r[1], r[2], r[3]) for r in rows}
    27	
    28	
    29	def _cap_row(c, sanity=None):
    30	    sanity_ok, sanity_reason, sanity_checked_at = sanity if sanity is not None else (None, None, None)
    31	    return {"intent_tags": c.intent_tags.split(",") if c.intent_tags else [],
    32	            "input_types": c.input_types.split(",") if c.input_types else [],
    33	            "output_types": c.output_types.split(",") if c.output_types else [],
    34	            "side_effect": c.side_effect, "confidence": c.confidence,
    35	            "sanity_ok": bool(sanity_ok) if sanity_ok is not None else None,
    36	            "sanity_reason": sanity_reason or "",
    37	            "sanity_checked_at": sanity_checked_at}
    38	
    39	
    40	def _caps(session, slug):
    41	    rows = session.exec(select(Capability).where(Capability.cli_slug == slug)).all()
    42	    sanity_by_slug = _sanity_by_slug(session)
    43	    return [_cap_row(c, sanity_by_slug.get(c.cli_slug)) for c in rows]
    44	
    45	
    46	def overview_rows(session):
    47	    clis = session.exec(select(Cli)).all()
    48	    caps = session.exec(select(Capability)).all()
    49	    edges = session.exec(select(CliEdge)).all()
    50	    sanity_by_slug = _sanity_by_slug(session)
    51	
    52	    caps_by_slug = {}
    53	    for cap in caps:
    54	        caps_by_slug.setdefault(cap.cli_slug, []).append(_cap_row(cap, sanity_by_slug.get(cap.cli_slug)))
    55	
    56	    return {
    57	        "clis": [
    58	            {"slug": c.slug, "lang": c.lang, "project": c.project,
    59	             "description": c.description, "health_status": _norm_health(c.health_status)}
    60	            for c in clis
    61	        ],
    62	        "caps_by_slug": caps_by_slug,
    63	        "edges": [
    64	            {"from": e.from_slug, "to": e.to_slug, "via_type": e.via_type}
    65	            for e in edges
    66	        ],
    67	    }
    68	
    69	
    70	def search_clis(session, query: str = ""):
    71	    rows = session.exec(select(Cli)).all()
    72	    q = query.strip().lower()
    73	    if not q:
    74	        return [_search_row(c) for c in rows]
    75	    caps = session.exec(select(Capability)).all()
    76	    vocab_by_slug: dict[str, str] = {}
    77	    for cap in caps:
    78	        blob = " ".join([cap.intent_tags, cap.input_types, cap.output_types])
    79	        vocab_by_slug[cap.cli_slug] = (
    80	            vocab_by_slug.get(cap.cli_slug, "") + " " + blob
    81	        ).lower()
    82	    return [
    83	        _search_row(c) for c in rows
    84	        if q in (c.slug + " " + c.description).lower()
    85	        or q in vocab_by_slug.get(c.slug, "")
    86	    ]
    87	
    88	
    89	def _search_row(c) -> dict:
    90	    return {"slug": c.slug, "lang": c.lang, "description": c.description,
    91	            "health_status": _norm_health(c.health_status)}
    92	
    93	
    94	def describe_cli(session, slug: str, include_launch_spec: bool = False):
    95	    c = session.get(Cli, slug)
    96	    if c is None:
    97	        return None
    98	    out = {"slug": c.slug, "lang": c.lang, "description": c.description,
    99	           "health_status": _norm_health(c.health_status), "capabilities": _caps(session, slug)}
   100	    if include_launch_spec:
   101	        out["launch_spec"] = c.launch_spec
   102	    return out
   103	
   104	
   105	def cli_health(session, slug: str):
   106	    c = session.get(Cli, slug)
   107	    if c is None:
   108	        return {"slug": slug, "health_status": "unknown"}
   109	    return {"slug": slug, "health_status": _norm_health(c.health_status),
   110	            "checked_at": c.health_checked_at}
   111	
   112	
   113	def cli_graph(session):
   114	    return [{"from": e.from_slug, "to": e.to_slug, "via_type": e.via_type}
   115	            for e in session.exec(select(CliEdge)).all()]
   116	
   117	
   118	def export_rows(session):
   119	    """Full, deterministically-ordered rows for OKF export.
   120	
   121	    Unlike overview_rows/describe_cli this carries `path` and `updated_at`
   122	    (needed for OKF `resource`/`timestamp`) and a fully sorted shape so the
   123	    producer can emit byte-stable bundles. Fails loudly if a CLI has >1
   124	    capability row (OKF v1 exports the one-capability-per-CLI invariant).
   125	    """
   126	    clis = session.exec(select(Cli)).all()
   127	    caps_by_slug = {}
   128	    for cap in session.exec(select(Capability)).all():
   129	        caps_by_slug.setdefault(cap.cli_slug, []).append(cap)
   130	    edges_by_slug = {}
   131	    for e in session.exec(select(CliEdge)).all():
   132	        edges_by_slug.setdefault(e.from_slug, []).append(e)
   133	
   134	    out = []
   135	    for c in sorted(clis, key=lambda x: ((x.project or ""), x.slug)):
   136	        caps = caps_by_slug.get(c.slug, [])
   137	        if len(caps) > 1:
   138	            raise ValueError(
   139	                f"OKF export: CLI {c.slug!r} has {len(caps)} capability rows; "
   140	                "v1 exports one capability per CLI")
   141	        cap = caps[0] if caps else None
   142	        capability = None
   143	        if cap is not None:
   144	            capability = {
   145	                "intent_tags": sorted(t for t in cap.intent_tags.split(",") if t),
   146	                "input_types": sorted(t for t in cap.input_types.split(",") if t),
   147	                "output_types": sorted(t for t in cap.output_types.split(",") if t),
   148	                "side_effect": cap.side_effect,
   149	                "confidence": cap.confidence,
   150	            }
   151	        edges = sorted(
   152	            ({"to": e.to_slug, "via": e.via_type} for e in edges_by_slug.get(c.slug, [])),
   153	            key=lambda d: (d["to"], d["via"]),
   154	        )
   155	        out.append({
   156	            "slug": c.slug, "lang": c.lang, "project": c.project, "path": c.path,
   157	            "updated_at": c.updated_at, "description": c.description or "",  # normalise NULL -> "" for OKF consumers
   158	            "health_status": _norm_health(c.health_status),
   159	            "capability": capability, "edges": edges,
   160	        })
   161	    return out
   162	
   163	
   164	def plan_cli_chain(session, goal_inputs, goal_outputs, allow_side_effects=None):
   165	    chains = _plan(session, goal_inputs, goal_outputs, allow_side_effects or [])
   166	    health_by_slug = {}
   167	
   168	    def _health(slug):
   169	        if slug not in health_by_slug:
   170	            c = session.get(Cli, slug)
   171	            health_by_slug[slug] = _norm_health(c.health_status) if c else "unknown"
   172	        return health_by_slug[slug]
   173	
   174	    out = []
   175	    for ch in chains:
   176	        hops = [{**hop, "health_status": _health(hop["slug"])} for hop in ch.hops]
   177	        out.append({"slugs": ch.slugs, "length": ch.length,
   178	                    "side_effect_count": ch.side_effect_count, "hops": hops})
   179	    return out

