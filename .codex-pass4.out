   897	    else:
   898	        try:
   899	            plan_json = await _mcp_call("plan_cli_chain", {
   900	                "goal_inputs": tags["goal_inputs"],
   901	                "goal_outputs": tags["goal_outputs"],
   902	                "allow_side_effects": tags["side_effects"],
   903	            })
   904	            logger.debug("run_cli_command step4 plan", extra={"plan_json": plan_json})
   905	            chain = _select_chain(plan_json)
   906	        except Exception as e:  # noqa: BLE001
   907	            logger.debug("run_cli_command step4 plan/select failed", extra={"error": str(e)})
   908	            return json.dumps({"status": "failed", "error": str(e)})
   909	    logger.debug("run_cli_command step4 selected", extra={"chain": chain})
   910	
   911	    # 5-6) resolve + execute each hop in sequence, framing hop N's stdout into
   912	    # hop N+1's dispatch input. A 1-slug chain runs this loop exactly once
   913	    # with prev_output=None, so dispatch_input == command — identical to the
   914	    # pre-fix single-hop behavior.
   915	    from hermes_adapter.config import hermes_cfg, resolve_exec_gateway_url
   916	
   917	    def _budgeted(payload: dict) -> str:
   918	        """Serialize + budget-check any response this loop returns — success
   919	        or failure. The first design draft only budget-checked the success
   920	        path, leaving every failure return unchecked."""
   921	        out = json.dumps(payload)
   922	        out_bytes = len(out.encode("utf-8"))
   923	        if budget.would_exceed(out_bytes):
   924	            return json.dumps({"status": "failed", "error": "tool-output budget exceeded"})
   925	        budget.charge(out_bytes)
   926	        return out
