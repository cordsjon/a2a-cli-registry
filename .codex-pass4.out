   802	    """Fused discover -> infer-tags -> plan -> execute (spec US-CLIREG-PLAN-HOP-01).
   803	
   804	    The command run on the gateway is lifted verbatim from the plan; it is never
   805	    synthesized by the model or the inference call. Handler-level failures return
   806	    {status:failed}; execution outcomes pass through run_on_gateway unchanged.
   807	    """
   808	    goal = args.get("goal")
   809	    if not isinstance(goal, str) or not goal.strip():
   810	        return json.dumps({"status": "failed", "error": "run_cli_command: 'goal' is required"})
   811	    goal = goal.strip()
   812	    logger.debug("run_cli_command step0 start", extra={"goal": goal})
   813	
   814	    # 0) fetch the registry-wide vocabulary so inference is constrained to tags
