   648	
   649	async def _candidate_vocab(catalog_json: str) -> set[str]:
   650	    """Capability vocabulary for the discovered CLIs, sourced from describe_cli
   651	    (catalog rows carry no capabilities). Union of input_types + output_types."""
   652	    slugs, _ = _candidate_slugs(catalog_json)
   653	    vocab: set[str] = set()
   654	    for slug in slugs:
   655	        try:
   656	            raw = await _mcp_call("describe_cli", {"slug": slug})
   657	        except Exception:  # noqa: BLE001 — a slug we can't describe just adds no vocab
   658	            continue
   659	        for row in _unwrap_mcp_json(raw):
   660	            if not isinstance(row, dict):
   661	                continue
   662	            for cap in row.get("capabilities") or []:
   663	                for k in ("input_types", "output_types"):
   664	                    vocab.update(cap.get(k) or [])
   665	    return vocab
