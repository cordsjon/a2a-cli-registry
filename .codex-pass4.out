    26	def call_mcp_tool(session, name: str, arguments: dict) -> dict:
    27	    try:
    28	        op = op_by_mcp_tool(name)
    29	    except KeyError:
    30	        return _error_block(f"unknown tool: {name}")
    31	
    32	    err = _validate_arguments(op, arguments)
    33	    if err:
    34	        return _error_block(err)
