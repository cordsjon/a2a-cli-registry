   856	        except Exception as e:  # noqa: BLE001
   857	            logger.debug("run_cli_command step2 discovery failed", extra={"query": output_term, "error": str(e)})
   858	            return json.dumps({"status": "failed", "error": f"discovery failed: {e}"})
   859	        all_slugs, healthy = _candidate_slugs(catalog_json)
   860	    logger.debug("run_cli_command step2 candidates", extra={"query": query_term,
   861	                                                              "all_slugs": sorted(all_slugs),
   862	                                                              "healthy": sorted(healthy)})
   863	    if not all_slugs:
   864	        return json.dumps({"status": "failed",
   865	                           "error": f"no CLI catalog entries for inferred capabilities: {sorted(tags['goal_outputs'] + tags['goal_inputs'])}"})
   866	
   867	    # 3) vocab guard — validated against the FULL registry vocabulary (step 0),
   868	    #    not _candidate_vocab(catalog_json) (US-CLIREG-VOCAB-SCOPE-01). The
   869	    #    step-2 catalog is narrowed to goal_outputs[0] alone, so on any
   870	    #    transform goal (input type != output type) a real goal_inputs tag
   871	    #    belongs to a CLI that never entered that narrowed candidate set and
   872	    #    would be falsely rejected as "not in registry vocabulary". "Is this
   873	    #    tag real?" is a registry-wide question (full_vocab answers it); "can
   874	    #    a discovered CLI route this?" is answered downstream by step 4's
   875	    #    plan_cli_chain/_select_chain. A missing full_vocab (step-0 fetch
   876	    #    failure) skips this guard rather than hard-failing on it.
   877	    if full_vocab is not None:
   878	        inferred = set(tags["goal_inputs"]) | set(tags["goal_outputs"])
   879	        unknown = inferred - full_vocab
   880	        if unknown:
   881	            logger.debug("run_cli_command step3 vocab reject", extra={"unknown": sorted(unknown)})
   882	            return json.dumps({"status": "failed",
   883	                               "error": f"inferred capability not in registry vocabulary: {sorted(unknown)}"})
   884	
   885	    # 4) plan + select the healthy chain (single- or multi-hop, up to the cap).
   886	    #    BYPASS: plan_cli_chain plans from the tags alone — it never receives
