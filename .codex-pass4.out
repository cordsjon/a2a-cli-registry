   622	def _now() -> float:
   623	    return time.monotonic()
   624	
   625	
   626	async def _full_catalog_vocab() -> set[str]:
   627	    """Registry-wide capability vocabulary (US-CLIREG-VOCAB-GROUND-01, AC-01).
   628	
   629	    Sourced the same way as _candidate_vocab (describe_cli fan-out), but over
   630	    the FULL unfiltered catalog (query="") instead of a tag-narrowed one, and
   631	    cached for _FULL_VOCAB_TTL_S — computing this fresh on every request would
   632	    mean hundreds of describe_cli round-trips per call."""
   633	    if _full_vocab_cache["value"] is not None and _now() < _full_vocab_cache["expires_at"]:
   634	        return _full_vocab_cache["value"]
   635	    catalog_json = await _mcp_call("search_cli_catalog", {"query": ""})
   636	    raw_vocab = await _candidate_vocab(catalog_json)
   637	    # core/vocabulary.py's admit() quarantines unregistered ports into an
   638	    # "unverified:" namespace and excludes them from edges/planning
   639	    # (is_edge_eligible) — describe_cli still surfaces them as capabilities,
   640	    # so offering them to the model just reproduces the original bug (it
   641	    # picks the semantically obvious unverified:file:markdown over the real
   642	    # file:md, then plan_cli_chain can never route through it).
   643	    vocab = {tag for tag in raw_vocab if not tag.startswith("unverified:")}
   644	    _full_vocab_cache["value"] = vocab
   645	    _full_vocab_cache["expires_at"] = _now() + _FULL_VOCAB_TTL_S
   646	    return vocab
