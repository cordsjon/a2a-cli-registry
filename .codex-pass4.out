   668	def _select_chain(plan_json: str) -> list[str]:
   669	    """Pick the ordered slug chain to run from the plan.
   670	
   671	    Selects the shortest chain whose hops are ALL healthy, subject to a hop
   672	    cap (_MAX_HOPS_PER_CHAIN). Pure/sync — no I/O; the caller resolves each
   673	    slug to a command via _resolve_command.
   674	
   675	    Healthiness is read from each hop's own `health_status` (as reported by
   676	    plan_cli_chain), NOT re-derived against a second, narrower candidate set.
   677	    A prior version also required `set(slugs) <= healthy_slugs`, where
   678	    `healthy_slugs` came from search_cli_catalog(query=goal_outputs[0]) — a
   679	    catalog narrowed to the OUTPUT type. A hop slug can be a real, healthy CLI
   680	    that simply never matches that output-scoped query (e.g. a generic
   681	    file-listing CLI as the first hop of a text-output goal), so that check
   682	    wrongly rejected every chain built on it — surfacing as "no healthy
   683	    single-CLI chain for goal" despite a valid, healthy chain existing."""
   684	    chains = _unwrap_mcp_json(plan_json)
   685	    if not chains:
   686	        raise ValueError("no usable plan: plan_cli_chain returned no chains")
   687	
   688	    def _all_healthy(ch: dict) -> bool:
   689	        hops = ch.get("hops") or []
   690	        slugs = ch.get("slugs") or []
   691	        if not slugs or not hops:
   692	            return False
   693	        # US-CLIREG-MULTIHOP-CHAIN-01 (Codex review): the original check only
   694	        # verified every HOP entry present was healthy, never that every SLUG
   695	        # had a corresponding hop entry at all. A planner response with fewer
   696	        # hop-health records than slugs would silently let an unchecked slug
   697	        # through. Multi-hop execution actually runs every slug in the chain,
   698	        # so this gap is no longer inert.
   699	        if len(hops) != len(slugs):
   700	            return False
   701	        return all(str(h.get("health_status", "")).lower() in ("ok", "healthy") for h in hops)
   702	
   703	    healthy_chains = sorted((ch for ch in chains if isinstance(ch, dict) and _all_healthy(ch)),
   704	                            key=lambda ch: len(ch.get("slugs") or []))
   705	    if not healthy_chains:
   706	        raise ValueError("no healthy chain for goal")
   707	    best = healthy_chains[0]
   708	    slugs = best.get("slugs") or []
   709	    if len(slugs) > _MAX_HOPS_PER_CHAIN:
   710	        raise ValueError(f"chain too long ({len(slugs)} hops, max {_MAX_HOPS_PER_CHAIN}): {slugs}")
   711	    logger.debug("run_cli_command chain selected", extra={"hop_count": len(slugs)})
   712	    return slugs
