   816	    # degrades to unconstrained inference (vocab=None) rather than failing the
   817	    # whole request on an unrelated registry outage.
   818	    try:
   819	        full_vocab = await _full_catalog_vocab()
   820	    except Exception:  # noqa: BLE001
   821	        full_vocab = None
   822	    logger.debug("run_cli_command step0 vocab", extra={"vocab_size": len(full_vocab) if full_vocab else 0})
   823	
   824	    # 1) infer capability tags (LLM) — MOVED FIRST so discovery can search by tag
   825	    try:
   826	        tags = await _infer_capability_tags(goal, vocab=full_vocab)
   827	    except Exception as e:  # noqa: BLE001
   828	        logger.debug("run_cli_command step1 infer failed", extra={"error": str(e)})
   829	        return json.dumps({"status": "failed", "error": f"could not infer capabilities: {e}"})
   830	    logger.debug("run_cli_command step1 tags", extra={"goal_inputs": tags["goal_inputs"],
   831	                                                        "goal_outputs": tags["goal_outputs"],
   832	                                                        "side_effects": tags["side_effects"]})
   833	
   834	    # 2) discover, scoped to the inferred capability. For a SIDE-EFFECT goal
   835	    # ('send email', 'post webhook') goal_outputs is the generic confirmation
   836	    # tag 'text', which matches ~200 CLIs and buries the one terminal CLI that
   837	    # actually performs the action — the planner then grabs an irrelevant
   838	    # top-ranked 'text' CLI (verify_potx/analyze_layouts). The side_effect term
   839	    # ('email') is the discriminating signal that surfaces the action CLI
   840	    # uniquely, so prefer it when present and it yields candidates; fall back to
   841	    # goal_outputs[0] otherwise (query goals, transform goals).
