   457	async def _dispatch(tool_name: str, args: dict, budget: OutputBudget) -> str:
   458	    """Shared handler body for the discovery/plan tools."""
   459	    try:
   460	        payload = await _mcp_call(tool_name, args)
   461	    except Exception as e:  # noqa: BLE001 — surfaced to the model, never crashes the round
   462	        return json.dumps({"status": "error", "error": f"{tool_name} failed: {e}"})
   463	    out_bytes = len(payload.encode("utf-8"))
   464	    if budget.would_exceed(out_bytes):
   465	        return json.dumps({"status": "error", "error": "tool-output budget exceeded"})
   466	    budget.charge(out_bytes)
   467	    return payload
   468	
