    # execute before planning. Defense-in-depth alongside the gateway approval gate.
    plan_id = args.get("plan_id")
    if not isinstance(plan_id, str) or not plan_id.strip():
        return json.dumps({
            "status": "denied",
            "reason": (
                "execute_cli_plan requires a plan_id from a prior plan_cli_chain "
                "call. Call plan_cli_chain first, then execute the returned plan."
            ),
        })

    base_url = resolve_exec_gateway_url(hermes_cfg)
    api_key = hermes_cfg.gateway_api_key
    async with httpx.AsyncClient(timeout=_HTTP_TIMEOUT_S) as client:
        result = await run_on_gateway(
            command.strip(), base_url=base_url, client=client, api_key=api_key
        )

    out = json.dumps(result)
    out_bytes = len(out.encode("utf-8"))
    if budget.would_exceed(out_bytes):
        return json.dumps({"status": "failed", "error": "tool-output budget exceeded"})
    budget.charge(out_bytes)
    return out


