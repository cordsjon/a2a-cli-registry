_MCP_TIMEOUT_S = 30.0


async def _mcp_call(tool_name: str, arguments: dict) -> str:
    """Dispatch one tool call to the cli-registry MCP and return its text payload.

    Uses the MCP streamable-HTTP protocol (initialize -> tools/call) via the
    official SDK, so the stateful session/SSE handshake (F7) is handled for us.
    Bearer + URL come from config (resolve_cli_registry_token / cli_registry_url).
    Isolated as a module-level seam so handlers are testable without a live MCP.
    """
    from mcp import ClientSession
    from mcp.client.streamable_http import streamablehttp_client

    from hermes_adapter.config import hermes_cfg, resolve_cli_registry_token

    url = hermes_cfg.cli_registry_url
    token = resolve_cli_registry_token(hermes_cfg)
    headers = {"Authorization": f"Bearer {token}"} if token else {}

    async with streamablehttp_client(url, headers=headers) as (read, write, _):
        async with ClientSession(read, write) as session:
            await session.initialize()
            result = await session.call_tool(tool_name, arguments)
    if getattr(result, "isError", False):
        raise RuntimeError(f"cli-registry MCP {tool_name} returned an error result")
    parts = []
    for block in getattr(result, "content", []) or []:
        text = getattr(block, "text", None)
        if text:
            parts.append(text)
    return "\n".join(parts)


async def _dispatch(tool_name: str, args: dict, budget: OutputBudget) -> str:
    """Shared handler body for the discovery/plan tools."""
    try:
        payload = await _mcp_call(tool_name, args)
    except Exception as e:  # noqa: BLE001 — surfaced to the model, never crashes the round
        return json.dumps({"status": "error", "error": f"{tool_name} failed: {e}"})
    out_bytes = len(payload.encode("utf-8"))
    if budget.would_exceed(out_bytes):
        return json.dumps({"status": "error", "error": "tool-output budget exceeded"})
    budget.charge(out_bytes)
    return payload


async def handle_search_cli_catalog(args: dict, budget: OutputBudget) -> str:
    "For an ACTION goal whose point is a side effect rather than a produced file "
    "(e.g. 'send an email', 'post a webhook', 'write X to a file') there is likewise "
    "no output artifact — the command returns a confirmation, not a file. Use 'text' "
    "as goal_outputs for that confirmation, and put the action in side_effects. "
    "goal_outputs must never be empty, even for pure side-effect goals. "
    "side_effects = side-effect classes the goal explicitly asks for (e.g. email, file_write). "
    "No prose, no code fences."
)
_TAG_INFER_MAX_TOKENS = 128


async def _infer_capability_tags(goal: str, vocab: set[str] | None = None) -> dict:
    """Goal -> {goal_inputs, goal_outputs, side_effects}. Raises ValueError if the
    model output is unparseable or names no output capability (never fabricates).

    If `vocab` is supplied (the registry's real <category>:<subtype> tags), any
    inferred tag outside it triggers one retry that tells the model exactly which
    tags were rejected; still out-of-vocab after the retry raises ValueError.
    `vocab=None` skips the check (e.g. registry vocab fetch failed upstream) —
    the caller degrades to the pre-fix unconstrained behavior rather than
    hard-failing on an unrelated outage."""
    from hermes_adapter.config import hermes_cfg
    from hermes_adapter.loop import _API_ROUTER_URL, _call_gateway as _fn

    headers = {"Content-Type": "application/json"}

    async def _call(user_msg: str) -> dict:
        async with httpx.AsyncClient(timeout=_HTTP_TIMEOUT_S) as client:
            content, _usage = await _fn(
                client, _API_ROUTER_URL, headers,
                _TAG_INFER_SYSTEM, user_msg, hermes_cfg.model, _TAG_INFER_MAX_TOKENS, 1.0,
            )
        try:
            data = json.loads(content.strip())
        except (json.JSONDecodeError, AttributeError) as e:
            raise ValueError(f"tag inference returned non-JSON: {e}") from e
        gi = data.get("goal_inputs") or []
        go = data.get("goal_outputs") or []
        se = data.get("side_effects") or []
        if not isinstance(go, list) or not go:
            raise ValueError("tag inference produced no goal_outputs")
        # The model is instructed to return tag strings, but nothing enforces that
        # shape — coerce here so every downstream consumer (set(), sorted()) can
        # trust a flat list of strings instead of raising on stray dict/list tags.
        gi = [t for t in gi if isinstance(t, str)]
        go = [t for t in go if isinstance(t, str)]
        se = [t for t in se if isinstance(t, str)]
        if not go:
            raise ValueError("tag inference produced no valid string goal_outputs")
        return {"goal_inputs": gi, "goal_outputs": go, "side_effects": se}

    tags = await _call(goal)
    if vocab is None:
        return tags

    rejected = (set(tags["goal_inputs"]) | set(tags["goal_outputs"])) - vocab
    if not rejected:
        return tags

    retry_msg = (
        f"{goal}\n\nYour previous answer used these tags, which do not exist in "
        f"the registry: {sorted(rejected)}. Choose ONLY from this exact vocabulary: "
        f"{sorted(vocab)}."
    )
    tags = await _call(retry_msg)
    rejected = (set(tags["goal_inputs"]) | set(tags["goal_outputs"])) - vocab
    if rejected:
        # The registry vocab is an I/O-PORT vocabulary (text, file:pdf, json...),
        # not an action vocabulary — so action/terminal goals ("send mail", "post
        # webhook") legitimately infer domain tags with no port equivalent. After
        # one corrective retry, QUARANTINE the still-rejected tags (drop them)
        # rather than hard-failing the hop, mirroring admit_ports' populate-time
        # behavior. Only fail if quarantine leaves no valid goal_outputs at all —
        # that means the inference was genuinely unusable, not just port-less.
        tags["goal_inputs"] = [t for t in tags["goal_inputs"] if t in vocab]
        tags["goal_outputs"] = [t for t in tags["goal_outputs"] if t in vocab]
        if not tags["goal_outputs"]:
            raise ValueError(
                f"tag inference produced only out-of-vocab tags after retry: {sorted(rejected)}"
            )
    return tags


def _unwrap_mcp_json(raw: str) -> list:
    """Return the result list from an MCP tool payload.

    Live registry shape: {"content": [{"type": "json", "json": [...]}]}.
    describe_cli returns content[0].json as a SINGLE object (not a list);
    search_cli_catalog / plan_cli_chain return lists. A singular dict is
    normalized to a one-element list so callers handle one shape.
    Legacy/test flat shape: {"results"|"clis"|"chains"|"steps": [...]}.
    Anything else (parse error, unexpected shape) yields []."""
    try:
        data = json.loads(raw)
    except (ValueError, TypeError):
        return []
    if isinstance(data, dict):
        content = data.get("content")
        if isinstance(content, list) and content:
            inner = content[0].get("json") if isinstance(content[0], dict) else None
            if isinstance(inner, list):
                return inner
            if isinstance(inner, dict):
                return [inner]
            return []
        for key in ("results", "clis", "chains", "steps"):
            if isinstance(data.get(key), list):
                return data[key]
    return []


def _candidate_slugs(catalog_json: str) -> tuple[set[str], set[str]]:
    results = _unwrap_mcp_json(catalog_json)
    all_slugs, healthy = set(), set()
    for c in results:
        if not isinstance(c, dict):
            continue
        slug = c.get("slug")
        if not slug:
            continue
        all_slugs.add(slug)
        status = c.get("health_status", c.get("health", ""))
        if str(status).lower() in ("ok", "healthy"):
            healthy.add(slug)
    return all_slugs, healthy


_FULL_VOCAB_TTL_S = 300  # registry composition changes rarely; avoid a 474-CLI
                         # describe_cli fan-out on every run_cli_command call
_full_vocab_cache: dict[str, Any] = {"value": None, "expires_at": 0.0}


def _now() -> float:
    return time.monotonic()


async def _full_catalog_vocab() -> set[str]:
    """Registry-wide capability vocabulary (US-CLIREG-VOCAB-GROUND-01, AC-01).

    Sourced the same way as _candidate_vocab (describe_cli fan-out), but over
    the FULL unfiltered catalog (query="") instead of a tag-narrowed one, and
    cached for _FULL_VOCAB_TTL_S — computing this fresh on every request would
    mean hundreds of describe_cli round-trips per call."""
    if _full_vocab_cache["value"] is not None and _now() < _full_vocab_cache["expires_at"]:
        return _full_vocab_cache["value"]
    catalog_json = await _mcp_call("search_cli_catalog", {"query": ""})
    raw_vocab = await _candidate_vocab(catalog_json)
    # core/vocabulary.py's admit() quarantines unregistered ports into an
    # "unverified:" namespace and excludes them from edges/planning
    # (is_edge_eligible) — describe_cli still surfaces them as capabilities,
    # so offering them to the model just reproduces the original bug (it
    # picks the semantically obvious unverified:file:markdown over the real
    # file:md, then plan_cli_chain can never route through it).
    vocab = {tag for tag in raw_vocab if not tag.startswith("unverified:")}
    _full_vocab_cache["value"] = vocab
    _full_vocab_cache["expires_at"] = _now() + _FULL_VOCAB_TTL_S
    return vocab


async def _candidate_vocab(catalog_json: str) -> set[str]:
    """Capability vocabulary for the discovered CLIs, sourced from describe_cli
    (catalog rows carry no capabilities). Union of input_types + output_types."""
    slugs, _ = _candidate_slugs(catalog_json)
    vocab: set[str] = set()
    for slug in slugs:
        try:
            raw = await _mcp_call("describe_cli", {"slug": slug})
        except Exception:  # noqa: BLE001 — a slug we can't describe just adds no vocab
            continue
        for row in _unwrap_mcp_json(raw):
            if not isinstance(row, dict):
                continue
            for cap in row.get("capabilities") or []:
                for k in ("input_types", "output_types"):
                    vocab.update(cap.get(k) or [])
    return vocab


def _select_chain(plan_json: str) -> list[str]:
    """Pick the ordered slug chain to run from the plan.

    Selects the shortest chain whose hops are ALL healthy, subject to a hop
    cap (_MAX_HOPS_PER_CHAIN). Pure/sync — no I/O; the caller resolves each
    slug to a command via _resolve_command.

    Healthiness is read from each hop's own `health_status` (as reported by
    plan_cli_chain), NOT re-derived against a second, narrower candidate set.
    A prior version also required `set(slugs) <= healthy_slugs`, where
    `healthy_slugs` came from search_cli_catalog(query=goal_outputs[0]) — a
    catalog narrowed to the OUTPUT type. A hop slug can be a real, healthy CLI
    that simply never matches that output-scoped query (e.g. a generic
    file-listing CLI as the first hop of a text-output goal), so that check
    wrongly rejected every chain built on it — surfacing as "no healthy
    single-CLI chain for goal" despite a valid, healthy chain existing."""
    chains = _unwrap_mcp_json(plan_json)
    if not chains:
        raise ValueError("no usable plan: plan_cli_chain returned no chains")

    def _all_healthy(ch: dict) -> bool:
        hops = ch.get("hops") or []
        slugs = ch.get("slugs") or []
        if not slugs or not hops:
            return False
        # US-CLIREG-MULTIHOP-CHAIN-01 (Codex review): the original check only
        # verified every HOP entry present was healthy, never that every SLUG
        # had a corresponding hop entry at all. A planner response with fewer
        # hop-health records than slugs would silently let an unchecked slug
        # through. Multi-hop execution actually runs every slug in the chain,
        # so this gap is no longer inert.
        if len(hops) != len(slugs):
            return False
        return all(str(h.get("health_status", "")).lower() in ("ok", "healthy") for h in hops)

    healthy_chains = sorted((ch for ch in chains if isinstance(ch, dict) and _all_healthy(ch)),
                            key=lambda ch: len(ch.get("slugs") or []))
    if not healthy_chains:
        raise ValueError("no healthy chain for goal")
    best = healthy_chains[0]
    slugs = best.get("slugs") or []
    if len(slugs) > _MAX_HOPS_PER_CHAIN:
        raise ValueError(f"chain too long ({len(slugs)} hops, max {_MAX_HOPS_PER_CHAIN}): {slugs}")
    logger.debug("run_cli_command chain selected", extra={"hop_count": len(slugs)})
    return slugs


def _frame_handoff(prev_output: str) -> str:
    """Wrap a prior hop's stdout as inert DATA for the next hop's dispatch,
    truncated to _MAX_HANDOFF_CHARS. Does not eliminate prompt-injection risk
    (run_on_gateway hands this to an opaque gateway agent, not a typed
    subprocess call) but bounds the blast radius and gives the gateway agent
    an explicit signal to discount the content as instructions.

async def handle_run_cli_command(args: dict, budget: OutputBudget) -> str:
    """Fused discover -> infer-tags -> plan -> execute (spec US-CLIREG-PLAN-HOP-01).

    The command run on the gateway is lifted verbatim from the plan; it is never
    synthesized by the model or the inference call. Handler-level failures return
    {status:failed}; execution outcomes pass through run_on_gateway unchanged.
    """
    goal = args.get("goal")
    if not isinstance(goal, str) or not goal.strip():
        return json.dumps({"status": "failed", "error": "run_cli_command: 'goal' is required"})
    goal = goal.strip()
    logger.debug("run_cli_command step0 start", extra={"goal": goal})

    # 0) fetch the registry-wide vocabulary so inference is constrained to tags
    # that actually exist (US-CLIREG-VOCAB-GROUND-01, AC-01). A fetch failure
    # degrades to unconstrained inference (vocab=None) rather than failing the
    # whole request on an unrelated registry outage.
    try:
        full_vocab = await _full_catalog_vocab()
    except Exception:  # noqa: BLE001
        full_vocab = None
    logger.debug("run_cli_command step0 vocab", extra={"vocab_size": len(full_vocab) if full_vocab else 0})

    # 1) infer capability tags (LLM) — MOVED FIRST so discovery can search by tag
    try:
        tags = await _infer_capability_tags(goal, vocab=full_vocab)
    except Exception as e:  # noqa: BLE001
        logger.debug("run_cli_command step1 infer failed", extra={"error": str(e)})
        return json.dumps({"status": "failed", "error": f"could not infer capabilities: {e}"})
    logger.debug("run_cli_command step1 tags", extra={"goal_inputs": tags["goal_inputs"],
                                                        "goal_outputs": tags["goal_outputs"],
                                                        "side_effects": tags["side_effects"]})

    # 2) discover, scoped to the inferred capability. For a SIDE-EFFECT goal
    # ('send email', 'post webhook') goal_outputs is the generic confirmation
    # tag 'text', which matches ~200 CLIs and buries the one terminal CLI that
    # actually performs the action — the planner then grabs an irrelevant
    # top-ranked 'text' CLI (verify_potx/analyze_layouts). The side_effect term
    # ('email') is the discriminating signal that surfaces the action CLI
    # uniquely, so prefer it when present and it yields candidates; fall back to
    # goal_outputs[0] otherwise (query goals, transform goals).
    side_effect_term = tags["side_effects"][0] if tags.get("side_effects") else None
    output_term = tags["goal_outputs"][0]
    all_slugs, healthy, query_term = set(), set(), output_term
    if side_effect_term:
        try:
            se_catalog = await _mcp_call("search_cli_catalog", {"query": side_effect_term})
            se_all, se_healthy = _candidate_slugs(se_catalog)
        except Exception:  # noqa: BLE001 — fall through to the output-term search
            se_all, se_healthy = set(), set()
        if se_all:
            all_slugs, healthy, query_term = se_all, se_healthy, side_effect_term
    if not all_slugs:
        try:
            catalog_json = await _mcp_call("search_cli_catalog", {"query": output_term})
        except Exception as e:  # noqa: BLE001
            logger.debug("run_cli_command step2 discovery failed", extra={"query": output_term, "error": str(e)})
            return json.dumps({"status": "failed", "error": f"discovery failed: {e}"})
        all_slugs, healthy = _candidate_slugs(catalog_json)
    logger.debug("run_cli_command step2 candidates", extra={"query": query_term,
                                                              "all_slugs": sorted(all_slugs),
                                                              "healthy": sorted(healthy)})
    if not all_slugs:
        return json.dumps({"status": "failed",
                           "error": f"no CLI catalog entries for inferred capabilities: {sorted(tags['goal_outputs'] + tags['goal_inputs'])}"})

    # 3) vocab guard — validated against the FULL registry vocabulary (step 0),
    #    not _candidate_vocab(catalog_json) (US-CLIREG-VOCAB-SCOPE-01). The
    #    step-2 catalog is narrowed to goal_outputs[0] alone, so on any
    #    transform goal (input type != output type) a real goal_inputs tag
    #    belongs to a CLI that never entered that narrowed candidate set and
    #    would be falsely rejected as "not in registry vocabulary". "Is this
    #    tag real?" is a registry-wide question (full_vocab answers it); "can
    #    a discovered CLI route this?" is answered downstream by step 4's
    #    plan_cli_chain/_select_chain. A missing full_vocab (step-0 fetch
    #    failure) skips this guard rather than hard-failing on it.
    if full_vocab is not None:
        inferred = set(tags["goal_inputs"]) | set(tags["goal_outputs"])
        unknown = inferred - full_vocab
        if unknown:
            logger.debug("run_cli_command step3 vocab reject", extra={"unknown": sorted(unknown)})
            return json.dumps({"status": "failed",
                               "error": f"inferred capability not in registry vocabulary: {sorted(unknown)}"})

    # 4) plan + select the healthy chain (single- or multi-hop, up to the cap).
    #    BYPASS: plan_cli_chain plans from the tags alone — it never receives
    #    step-2's narrowed candidates, so for a side-effect goal it re-ranks
    #    the ~200-CLI generic-'text' pool and returns an irrelevant chain even
    #    though discovery already isolated the one action CLI. When the
    #    side-effect discovery yielded exactly one healthy slug there is
    #    nothing left to plan: that slug IS the 1-hop chain. Ambiguous
    #    (0 or 2+ healthy) or output-term discovery still goes to the planner.
    if side_effect_term and query_term == side_effect_term and len(healthy) == 1:
        chain = [next(iter(healthy))]
        logger.debug("run_cli_command step4 planner bypassed",
                     extra={"chain": chain, "query": query_term})
    else:
        try:
            plan_json = await _mcp_call("plan_cli_chain", {
                "goal_inputs": tags["goal_inputs"],
                "goal_outputs": tags["goal_outputs"],
                "allow_side_effects": tags["side_effects"],
            })
            logger.debug("run_cli_command step4 plan", extra={"plan_json": plan_json})
            chain = _select_chain(plan_json)
        except Exception as e:  # noqa: BLE001
            logger.debug("run_cli_command step4 plan/select failed", extra={"error": str(e)})
            return json.dumps({"status": "failed", "error": str(e)})
    logger.debug("run_cli_command step4 selected", extra={"chain": chain})

    # 5-6) resolve + execute each hop in sequence, framing hop N's stdout into
    # hop N+1's dispatch input. A 1-slug chain runs this loop exactly once
    # with prev_output=None, so dispatch_input == command — identical to the
    # pre-fix single-hop behavior.
    from hermes_adapter.config import hermes_cfg, resolve_exec_gateway_url

    def _budgeted(payload: dict) -> str:
        """Serialize + budget-check any response this loop returns — success
        or failure. The first design draft only budget-checked the success
        path, leaving every failure return unchecked."""
        out = json.dumps(payload)
        out_bytes = len(out.encode("utf-8"))
        if budget.would_exceed(out_bytes):
            return json.dumps({"status": "failed", "error": "tool-output budget exceeded"})
        budget.charge(out_bytes)
CREATE TABLE capability (
	id INTEGER NOT NULL, 
	cli_slug VARCHAR NOT NULL, 
	intent_tags VARCHAR NOT NULL, 
	input_types VARCHAR NOT NULL, 
	output_types VARCHAR NOT NULL, 
	side_effect VARCHAR NOT NULL, 
	confidence VARCHAR NOT NULL, provenance TEXT, description_provenance TEXT, sanity_ok INTEGER, sanity_reason TEXT, sanity_checked_at REAL, 
	PRIMARY KEY (id), 
	FOREIGN KEY(cli_slug) REFERENCES cli (slug)
);
